MetaShader "GamebryoMaterial_declare"
{
	Name = "GamebryoMaterial";
	Type = rtrendercontext;
	Renderer "realtime"
	{
		Name = "GamebryoMaterial";
		FileName = "GamebryoShaders";
	}
}

