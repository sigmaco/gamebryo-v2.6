Logic
{
	Sub OnInit()
		Base_Enabled_OnChanged
		Dark_Enabled_OnChanged
		Detail_Enabled_OnChanged
		Decal_01_Enabled_OnChanged
		Decal_02_Enabled_OnChanged
		Decal_03_Enabled_OnChanged
		Normal_Enabled_OnChanged
		Parallax_Enabled_OnChanged
		Environment_Enabled_OnChanged
		Bump_Enabled_OnChanged
		Gloss_Enabled_OnChanged
		ProjectedLight_01_Enabled_OnChanged
		ProjectedLight_02_Enabled_OnChanged
		ProjectedLight_03_Enabled_OnChanged
		ProjectedShadow_01_Enabled_OnChanged
		ProjectedShadow_02_Enabled_OnChanged
		ProjectedShadow_03_Enabled_OnChanged
		Glow_Enabled_OnChanged
		
		Base_Transform_OnChanged
		Dark_Transform_OnChanged
		Detail_Transform_OnChanged
		Decal_01_Transform_OnChanged
		Decal_02_Transform_OnChanged
		Decal_03_Transform_OnChanged
		Normal_Transform_OnChanged
		Parallax_Transform_OnChanged
		Environment_Transform_OnChanged
		Bump_Transform_OnChanged
		Gloss_Transform_OnChanged
		ProjectedLight_01_Transform_OnChanged
		ProjectedLight_02_Transform_OnChanged
		ProjectedLight_03_Transform_OnChanged
		ProjectedShadow_01_Transform_OnChanged
		ProjectedShadow_02_Transform_OnChanged
		ProjectedShadow_03_Transform_OnChanged
		Glow_Transform_OnChanged		
	End Sub
	
	Function FindNextGroupAfter(aUIname)
		Dim curItem, grabNextGroup, c, i
		grabNextGroup = false
		c = PPG.PPGLayout.Count
		For i = 0 to c - 1
			set curItem = PPG.PPGLayout.Item( i )
			If curItem.Name = aUIname Then
			   grabNextGroup = true
			End if
			If grabNextGroup Then
				If curItem.Name = "GroupBegin" Then
					set FindNextGroupAfter = curItem
					Exit Function
				End if
			End if
		Next
	End Function
	
	Sub ShowGroup(aUIname,newState)
		Dim theGroup
		set theGroup = FindNextGroupAfter(aUIname)
		if newState = true Then
			theGroup.Label = "UV Transform"
		else
			theGroup.Label = ""
		End if
		Call theGroup.SetAttribute( siUIShowFrame, newState )
		PPG.Refresh
	End Sub
	
	Sub Base_Enabled_OnChanged()
		newState = true
		if Base_Enabled = 0 then
			newState = false
		End if
		Base.Show( newState )
		Base_TexSpace.Show( newState )
		Base_FilteringMode.Show( newState )
		Base_MipMapEnabled.Show( newState )
		Base_ApplyMode.Show( newState )
		Base_TexCoordEnabled.Show( newState )
		Call ShowGroup( "Base_ApplyMode", newState )
		Base_TexCoordEnabled_OnChanged()
	End Sub
	
	Sub Dark_Enabled_OnChanged()
		newState = true
		if Dark_Enabled = 0 then
			newState = false
