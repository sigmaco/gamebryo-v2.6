Layout "Default"
{
	Group "Material"
	{	
		Ambient;
		Diffuse;
		Specular;
		Emittance;
		Shininess;
		Alpha;
		Preview_Texture;
	}	
	Group "Base Map"
	{			
		Base_Enabled;					
		Base;
		Base_TexSpace;
		Base_FilteringMode;
		Base_MipMapEnabled;
		Base_ApplyMode;		
				
		Group "UV Transform"
		{
			Base_TexCoordEnabled;
			Group "Wrapping"
			{
				Base_wrap_u,LabelWidth(45%,120);
				Base_wrap_v,LabelWidth(45%,120);
				Base_wrap_w,LabelWidth(45%,120);
			}		
				
			Base_Transform;
			Group "Translation", continue
			{
				Base_trsx,LabelWidth(8%,8);
				Base_trsy,LabelWidth(8%,8);
				Base_trsz,LabelWidth(8%,8);
			}
			Group "Rotation", continue
			{
				Base_rotx,LabelWidth(8%,8);
				Base_roty,LabelWidth(8%,8);
				Base_rotz,LabelWidth(8%,8);
			}
			Group "Scaling"
			{
				Base_sclx,LabelWidth(8%,8);
				Base_scly,LabelWidth(8%,8);
				Base_sclz,LabelWidth(8%,8);
			}
		}				
	}	
	Group "Dark Map"
	{			
		Dark_Enabled;							
		Dark;
		Dark_TexSpace;
		Dark_FilteringMode;
		Dark_MipMapEnabled;
		Dark_ApplyMode;		
		
		Group "UV Transform"
		{		
			Dark_TexCoordEnabled;
			Group "Wrapping"
			{
				Dark_wrap_u,LabelWidth(45%,120);
				Dark_wrap_v,LabelWidth(45%,120);
				Dark_wrap_w,LabelWidth(45%,120);
			}		
					
			Dark_Transform;
			Group "Translation", continue
			{
				Dark_trsx,LabelWidth(8%,8);
				Dark_trsy,LabelWidth(8%,8);
				Dark_trsz,LabelWidth(8%,8);
			}
			Group "Rotation", continue
			{
				Dark_rotx,LabelWidth(8%,8);
				Dark_roty,LabelWidth(8%,8);
				Dark_rotz,LabelWidth(8%,8);
			}
			Group "Scaling"
			{
				Dark_sclx,LabelWidth(8%,8);
				Dark_scly,LabelWidth(8%,8);
				Dark_sclz,LabelWidth(8%,8);
			}
		}						
	}	
	Group "Detail Map"
