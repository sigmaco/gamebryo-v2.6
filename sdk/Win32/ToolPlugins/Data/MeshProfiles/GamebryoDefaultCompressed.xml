            <Element name="MORPH_NORMAL" range="0-31" convertformat="FLOAT16">
                <Component value="MORPH_NORMAL[].x" />
                <Component value="MORPH_NORMAL[].y" />
                <Component value="MORPH_NORMAL[].z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" name="MORPH_NORMAL" range="0-31" convertformat="FLOAT16">
                <Component value="MORPH_NORMAL[].x" />
                <Component value="MORPH_NORMAL[].y" />
                <Component value="MORPH_NORMAL[].z" />
            </Element>
            <Element renderer="WII" name="MORPH_NORMAL" range="0-31">
                <Component value="MORPH_NORMAL[].x" />
                <Component value="MORPH_NORMAL[].y" />
                <Component value="MORPH_NORMAL[].z" />
            </Element>
            <Element name="MORPH_POSITION_BP" range="0-31" convertformat="FLOAT16">
                <Component value="MORPH_POSITION_BP[].x" />
                <Component value="MORPH_POSITION_BP[].y" />
                <Component value="MORPH_POSITION_BP[].z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" name="MORPH_POSITION_BP" range="0-31" convertformat="FLOAT16">
                <Component value="MORPH_POSITION_BP[].x" />
                <Component value="MORPH_POSITION_BP[].y" />
                <Component value="MORPH_POSITION_BP[].z" />
            </Element>
            <Element renderer="WII" name="MORPH_POSITION_BP" range="0-31">
                <Component value="MORPH_POSITION_BP[].x" />
                <Component value="MORPH_POSITION_BP[].y" />
                <Component value="MORPH_POSITION_BP[].z" />
            </Element>
            <Element name="MORPH_NORMAL_BP" range="0-31" convertformat="FLOAT16">
                <Component value="MORPH_NORMAL_BP[].x" />
                <Component value="MORPH_NORMAL_BP[].y" />
                <Component value="MORPH_NORMAL_BP[].z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" name="MORPH_NORMAL_BP" range="0-31" convertformat="FLOAT16">
                <Component value="MORPH_NORMAL_BP[].x" />
                <Component value="MORPH_NORMAL_BP[].y" />
                <Component value="MORPH_NORMAL_BP[].z" />
