            <Element type="BLENDWEIGHT" convertformat="FLOAT16">
                <Component value="BLENDWEIGHT.0" />
                <Component value="BLENDWEIGHT.1" />
                <Component value="BLENDWEIGHT.2" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" type="BLENDWEIGHT" convertformat="FLOAT16">
                <Component value="BLENDWEIGHT.0" />
                <Component value="BLENDWEIGHT.1" />
                <Component value="BLENDWEIGHT.2" />
            </Element>
        </FinalizeStream>
        <FinalizeStream renderer="WII" name="WiiNBTVertexStream">
            <Element renderer="WII" type="NORMAL" convertformat="INT16" converttype="NORMALIZE" strict="STRICT_FORMAT">
                <Component value="NORMAL.x" />
                <Component value="NORMAL.y" />
                <Component value="NORMAL.z" />
            </Element>
            <Element renderer="WII" type="BINORMAL" range="0-7" convertformat="INT16" converttype="NORMALIZE" strict="STRICT_FORMAT">
                <Component value="BINORMAL[].x" />
                <Component value="BINORMAL[].y" />
                <Component value="BINORMAL[].z" />
            </Element>
            <Element renderer="WII" type="TANGENT" range="0-7" convertformat="INT16" converttype="NORMALIZE" strict="STRICT_FORMAT">
                <Component value="TANGENT[].x" />
                <Component value="TANGENT[].y" />
                <Component value="TANGENT[].z" />
            </Element>
            <Element renderer="WII" type="NORMAL_BP" convertformat="INT16" converttype="NORMALIZE" strict="STRICT_FORMAT">
                <Component value="NORMAL_BP.x" />
                <Component value="NORMAL_BP.y" />
                <Component value="NORMAL_BP.z" />
