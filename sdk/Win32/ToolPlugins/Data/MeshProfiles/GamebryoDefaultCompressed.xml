                <Component value="NORMAL_BP.y" />
                <Component value="NORMAL_BP.z" />
            </Element>
            <Element type="BINORMAL_BP" range="0-7" convertformat="FLOAT16">
                <Component value="BINORMAL_BP[].x" />
                <Component value="BINORMAL_BP[].y" />
                <Component value="BINORMAL_BP[].z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" type="BINORMAL_BP" range="0-7" convertformat="FLOAT16">
                <Component value="BINORMAL_BP[].x" />
                <Component value="BINORMAL_BP[].y" />
                <Component value="BINORMAL_BP[].z" />
            </Element>
            <Element type="TANGENT_BP" range="0-7" convertformat="FLOAT16">
