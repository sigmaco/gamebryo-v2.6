        <FinalizeStream name="MorphWeightStream">
            <Element>MORPHWEIGHTS</Element>
        </FinalizeStream>
        <FinalizeStream name="BoneIndexRemapStream">
            <Element>BONE_PALETTE</Element>
        </FinalizeStream>
        <FinalizeStream name="TransformsStream">
            <Element range="0-2">TRANSFORMS</Element>
        </FinalizeStream>
        <FinalizeStream name="InstanceTransformsStream">
            <Element range="0-2">INSTANCETRANSFORMS</Element>
        </FinalizeStream>
        <FinalizeStream name="NormalShareIndexStream">
            <Element>NORMALSHAREINDEX</Element>
        </FinalizeStream>
        <FinalizeStream name="NormalShareGroupStream">
