<?xml version="1.0" encoding="utf-8"?>
<MeshProfiles version="1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="./NiMeshProfileSchema.xsd">
    <MeshProfile name="DefaultCompressed" description="Default compressed mesh profile">
        <FinalizeStream name="Indices">
            <Element convertformat="UINT16" converttype="SMARTCLAMP">INDEX</Element>
        </FinalizeStream>
	<FinalizeStream renderer="WII" name="BaseVertexStream">
            <Element renderer="WII">POSITION</Element>
            <Element renderer="WII" type="COLOR" convertformat="UINT8" converttype="NORMALIZE" range="0-7">COLOR</Element>
            <Element renderer="WII" range="0-7">TEXCOORD</Element>
            <Element renderer="WII">POSITION_BP</Element>
            <Element renderer="WII" convertformat="UINT8" converttype="SMARTCLAMP">BLENDINDICES</Element>
            <Element renderer="WII" type="BLENDWEIGHT" convertformat="UINT8" converttype="NORMALIZE">
                <Component value="BLENDWEIGHT.0" />
                <Component value="BLENDWEIGHT.1" />
                <Component value="BLENDWEIGHT.2" />
                <Component value="BLENDWEIGHT.3" />
            </Element>
        </FinalizeStream>
        <FinalizeStream name="BaseVertexStream">
            <Element type="POSITION" convertformat="FLOAT16">
                <Component value="POSITION.x" />
                <Component value="POSITION.y" />
                <Component value="POSITION.z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" type="POSITION" convertformat="FLOAT16">
                <Component value="POSITION.x" />
                <Component value="POSITION.y" />
                <Component value="POSITION.z" />
            </Element>
            <Element type="NORMAL" convertformat="FLOAT16">
                <Component value="NORMAL.x" />
                <Component value="NORMAL.y" />
                <Component value="NORMAL.z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" type="NORMAL" convertformat="FLOAT16">
                <Component value="NORMAL.x" />
                <Component value="NORMAL.y" />
                <Component value="NORMAL.z" />
            </Element>
            <Element type="BINORMAL" range="0-7" convertformat="FLOAT16">
                <Component value="BINORMAL[].x" />
                <Component value="BINORMAL[].y" />
                <Component value="BINORMAL[].z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" type="BINORMAL" range="0-7" convertformat="FLOAT16">
                <Component value="BINORMAL[].x" />
                <Component value="BINORMAL[].y" />
                <Component value="BINORMAL[].z" />
            </Element>
            <Element type="TANGENT" range="0-7" convertformat="FLOAT16">
                <Component value="TANGENT[].x" />
                <Component value="TANGENT[].y" />
                <Component value="TANGENT[].z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" type="TANGENT" range="0-7" convertformat="FLOAT16">
                <Component value="TANGENT[].x" />
                <Component value="TANGENT[].y" />
                <Component value="TANGENT[].z" />
            </Element>
            <Element type="COLOR" convertformat="UINT8" converttype="NORMALIZE" range="0-7">COLOR</Element>
            <Element convertformat="FLOAT16" range="0-7">TEXCOORD</Element>
            <Element type="POSITION_BP" convertformat="FLOAT16">
                <Component value="POSITION_BP.x" />
                <Component value="POSITION_BP.y" />
                <Component value="POSITION_BP.z" />
                <Component value="1.0" />
            </Element>
            <Element renderer="PS3" type="POSITION_BP" convertformat="FLOAT16">
                <Component value="POSITION_BP.x" />
                <Component value="POSITION_BP.y" />
                <Component value="POSITION_BP.z" />
