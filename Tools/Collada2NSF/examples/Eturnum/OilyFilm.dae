	<library_materials>
		<material id="Material0" name="OilyFilm">
			<instance_effect url="#OilyFilm0">
				<technique_hint platform="PS3" ref="main"/>
				<technique_hint platform="PC-OGL" ref="main"/>
				<setparam ref="WorldViewProj">
					<float4x4>-0.343435 0 -1.50018 -1.5 0 2.74748 0 0 -4.12122 0 0.125015 0.125 -5.49495 0 4.74421 4.74525</float4x4>
				</setparam>
				<setparam ref="InvWorld">
					<float4x4>-0.0551724 -0 -0.662069 -0 0 1 0 0 0.662069 0 -0.0551724 0 -0.110345 -0 -1.32414 1</float4x4>
				</setparam>
				<setparam ref="EyePos">
					<float4>0 0 0 0</float4>
				</setparam>
				<setparam ref="Zoze">
					<float4>0 1 0 1</float4>
				</setparam>
				<setparam ref="Exponent">
					<float>64</float>
				</setparam>
				<setparam ref="WarpAlpha">
					<float>1</float>
				</setparam>
				<setparam ref="Light1Direction">
					<float3>0 0 0</float3>
				</setparam>
				<setparam ref="Light2Direction">
					<float3>0 0 0</float3>
				</setparam>
				<setparam ref="Light1Color">
					<float3>0 0 0</float3>
				</setparam>
				<setparam ref="Light2Color">
					<float3>0 0 0</float3>
				</setparam>
				<setparam ref="BaseTexture">
					<surface type="2D">
						<init_as_null/>
						<format>A8R8G8B8</format>
						<size>64 64 1</size>
					</surface>
				</setparam>
				<setparam ref="filmRamp">
					<surface type="1D">
						<init_from>thinFilmRamp</init_from>
						<format>Unknown</format>
						<size>64 64 1</size>
					</surface>
				</setparam>
				<setparam ref="warpEffect">
					<surface type="2D">
						<init_from>WarpEffects</init_from>
						<format>Unknown</format>
						<size>64 64 1</size>
					</surface>
				</setparam>
			</instance_effect>
		</material>
	</library_materials>
</COLLADA>
