								<param ref="Light1Color"/>
							</bind>
							<bind symbol="Light2Color">
								<param ref="Light2Color"/>
							</bind>
						</shader>
						<shader stage="FRAGMENT">
							<compiler_target>arbfp1</compiler_target>
							<name source="OilyFilm_main_p0_fmain_compiled">fmain</name>
							<bind symbol="WarpAlpha">
								<param ref="WarpAlpha"/>
							</bind>
							<bind symbol="BaseMapSampler">
								<param ref="BaseMapSampler"/>
							</bind>
							<bind symbol="OilyFilm">
								<param ref="OilyFilm"/>
							</bind>
							<bind symbol="WarpSampler">
								<param ref="WarpSampler"/>
							</bind>
						</shader>
						<extra type="passenable">
							<technique profile="NVIDIA_FXCOMPOSER">
								<true/>
							</technique>
						</extra>
					</pass>
					<extra type="import">
						<technique profile="NVIDIA_FXCOMPOSER">
							<import compiler_options=""/>
						</technique>
					</extra>
				</technique>
			</profile_CG>
		</effect>
