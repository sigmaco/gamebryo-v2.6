		<effect id="Skin2DirLightsWarpEffect0" name="Skin2DirLightsWarpEffect">
			<profile_CG platform="PC-OGL">
				<include sid="Skin2DirLightsWarpEffect" url="Skin2DirLightsWarpEffect.cgfx"/>
				<newparam sid="description">
					<annotate name="detail0">
						<string>This shader skins a model using 20 bones per partition, applies a base </string>
					</annotate>
					<annotate name="detail1">
						<string>map, and lights it with two directional lights using a normal map. </string>
					</annotate>
					<annotate name="detail3">
						<string>the shader to fade out over time. The warp effect is a 2D texture that </string>
					</annotate>
					<annotate name="detail5">
						<string>the V coordinate. This shader was used for the alien's skin in the </string>
					</annotate>
					<annotate name="detail2">
						<string>Then, the entire effect is modified by a warping effect that allows </string>
					</annotate>
					<annotate name="detail4">
						<string>will be sampled using (N dot V) as the U coordinate and 'warpAlpha' as </string>
					</annotate>
					<annotate name="detail6">
						<string>Eturnum sample.</string>
					</annotate>
					<string>Skin With 2 Directional Lights and Warp Effect</string>
				</newparam>
