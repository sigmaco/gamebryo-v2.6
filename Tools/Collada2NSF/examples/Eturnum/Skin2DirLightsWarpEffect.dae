						<magfilter>LINEAR</magfilter>
					</sampler2D>
				</newparam>
				<technique sid="main">
					<pass sid="p0">
						<blend_enable value="true"/>
						<blend_func>
							<src value="SRC_ALPHA"/>
							<dest value="ONE_MINUS_SRC_ALPHA"/>
						</blend_func>
						<polygon_mode>
							<face value="FRONT"/>
							<mode/>
						</polygon_mode>
						<shader stage="VERTEX">
							<compiler_target>arbvp1</compiler_target>
							<name source="Skin2DirLightsWarpEffect_main_p0_vmain_compiled">vmain</name>
							<bind symbol="ViewProjTranspose">
								<param ref="ViewProjTranspose"/>
							</bind>
							<bind symbol="EyePos">
								<param ref="EyePos"/>
							</bind>
							<bind symbol="MaterialDiffuse">
								<param ref="MaterialDiffuse"/>
							</bind>
							<bind symbol="SkinBoneMatrices">
								<param ref="SkinBoneMatrices"/>
							</bind>
							<bind symbol="Light1Direction">
								<param ref="Light1Direction"/>
							</bind>
							<bind symbol="Light2Direction">
								<param ref="Light2Direction"/>
							</bind>
						</shader>
						<shader stage="FRAGMENT">
							<compiler_target>arbfp1</compiler_target>
							<name source="Skin2DirLightsWarpEffect_main_p0_fmain_compiled">fmain</name>
							<bind symbol="WarpAlpha">
								<param ref="WarpAlpha"/>
							</bind>
							<bind symbol="Light1Color">
								<param ref="Light1Color"/>
							</bind>
							<bind symbol="Light2Color">
								<param ref="Light2Color"/>
							</bind>
							<bind symbol="BaseMapSampler">
								<param ref="BaseMapSampler"/>
							</bind>
							<bind symbol="WarpEffectSampler">
								<param ref="WarpEffectSampler"/>
							</bind>
							<bind symbol="NormalMapSampler">
								<param ref="NormalMapSampler"/>
							</bind>
						</shader>
						<extra type="passenable">
							<technique profile="NVIDIA_FXCOMPOSER">
								<true/>
							</technique>
						</extra>
					</pass>
					<extra type="import">
						<technique profile="NVIDIA_FXCOMPOSER">
							<import compiler_options=""/>
						</technique>
					</extra>
				</technique>
			</profile_CG>
		</effect>
