	<library_materials>
		<material id="Material0" name="Swoosh">
			<instance_effect url="#Swoosh0">
				<technique_hint platform="PC-D3D" ref="Constant"/>
				<technique_hint platform="PS3" ref="main"/>
				<technique_hint platform="PC-OGL" ref="main"/>
				<setparam ref="ViewProj">
					<float4x4>2.74748 0 0 0 0 2.74748 0 0 0 0 -1.00012 -1 0 0 4.74421 4.74525</float4x4>
				</setparam>
				<setparam ref="BaseTexture">
					<surface type="2D">
						<init_as_null/>
						<format>A8R8G8B8</format>
						<size>64 64 1</size>
					</surface>
				</setparam>
			</instance_effect>
		</material>
	</library_materials>
