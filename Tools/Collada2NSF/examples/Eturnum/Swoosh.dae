<?xml version="1.0"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
	<asset>
		<contributor>
			<author>ed.holzwarth</author>
			<authoring_tool>NVIDIA FX Composer 2.0</authoring_tool>
