					<annotate name="UIStep">
						<float>1</float>
					</annotate>
					<annotate name="UIMax">
						<float>1000</float>
					</annotate>
					<float>75</float>
				</newparam>
				<technique sid="main">
					<pass sid="p0">
						<blend_enable value="true"/>
						<alpha_test_enable value="true"/>
						<cull_face_enable value="true"/>
						<blend_func>
							<src/>
							<dest value="ONE"/>
