		<material id="Material0" name="BaseBumpWithSpatialGlow">
			<instance_effect url="#BaseBumpWithSpatialGlow0">
				<technique_hint platform="PS3" ref="main"/>
				<technique_hint platform="PC-D3D" ref="Constant"/>
				<technique_hint platform="PC-OGL" ref="main"/>
				<setparam ref="WorldViewProjTranspose">
					<float4x4>-0.343435 0 -4.12122 -5.49495 0 2.74748 0 0 -1.50018 0 0.125015 4.74421 -1.5 0 0.125 4.74525</float4x4>
				</setparam>
				<setparam ref="InvWorldTranspose">
					<float4x4>-0.0551724 0 0.662069 -0.110345 -0 1 0 -0 -0.662069 0 -0.0551724 -1.32414 -0 0 0 1</float4x4>
				</setparam>
				<setparam ref="GlowLightPosition">
					<float4>0 0 0 1</float4>
				</setparam>
				<setparam ref="Zoze">
					<float4>0 1 0 0.3</float4>
				</setparam>
				<setparam ref="GlowAttenuation">
					<float4>1 1 1 200</float4>
				</setparam>
				<setparam ref="Light1Direction">
					<float3>1.80992e-041 0 0</float3>
				</setparam>
				<setparam ref="Light2Direction">
					<float3>0 0 0</float3>
				</setparam>
				<setparam ref="Diffuse1">
					<float3>0 0 0</float3>
				</setparam>
				<setparam ref="Diffuse2">
					<float3>0 0 0</float3>
				</setparam>
				<setparam ref="BaseTexture">
					<surface type="2D">
						<init_as_null/>
						<format>A8R8G8B8</format>
						<size>0 0 1</size>
					</surface>
				</setparam>
