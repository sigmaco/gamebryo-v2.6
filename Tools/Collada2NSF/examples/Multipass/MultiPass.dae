                <include sid="MultipassSample_main_wavy_overlay0_vmain_pulsealpha_compiled" url="MultipassSample_main_wavy_overlay0.vpo"/>
                <include sid="MultipassSample_main_wavy_overlay0_fmain_tex_compiled" url="MultipassSample_main_wavy_overlay0.fpo"/>
